# .env.example
# Copy this file as `.env` and replace the values to match your environment.
#
# This file is loaded automatically by:
#   - docker-compose / docker-compose.db-only (the Compose CLI auto-loads .env from the project dir)
#   - The spring-boot-docker-compose integration on `./mvnw spring-boot:run`, since the
#     integration shells out to `docker compose`, which auto-loads .env.
#
# It is NOT loaded by Maven itself. When running outside Docker (`java -jar` against an external
# Postgres), export these variables in your shell or wire them into your IDE run configuration.
#
# ---- Variables MANDATORY when running with the production overlay ----
# `docker-compose.prod.yml` makes the following fail-fast (`${VAR:?...}`):
#   * JWT_SECRET_KEY            — no convenience default; must be a fresh 32-byte Base64 secret
#   * DB_PASSWORD               — no convenience default; never deploy with `changeme`
#   * CORS_ALLOWED_ORIGINS      — first-party SPA origin(s), comma-separated
#   * ACTUATOR_PASSWORD         — Basic-auth credential Prometheus uses to scrape /actuator/prometheus
# `docker compose -f docker-compose.yml -f docker-compose.prod.yml up` will exit immediately
# with a clear error if any of them is unset. The base `docker-compose.yml` keeps convenience
# defaults so a fresh clone can `docker compose up` without editing anything.

# ---- Spring profile ----
# `docker-compose.yml` already defaults SPRING_PROFILES_ACTIVE to `prod` so the full stack mirrors
# a real deployment (JSON logs, no Swagger UI, narrow Actuator surface, show-details=when-authorized).
# Override here to `dev` only if you want the dev experience inside the containerised app
# (Swagger UI, human-readable logs, wide Actuator surface). Leave commented for prod-like default.
# SPRING_PROFILES_ACTIVE=dev

# ---- Database ----
# DB_NAME is read by docker-compose to name the Postgres container and to build the JDBC URL
# (the URL points to the `db` service inside the Compose network).
DB_NAME=paydude_db
DB_USERNAME=postgres
# Convenience default for the base docker-compose.yml. The production overlay
# (docker-compose.prod.yml) makes DB_PASSWORD mandatory via `${DB_PASSWORD:?...}` —
# `changeme` will be rejected at `docker compose up` time.
DB_PASSWORD=changeme

# DB_URL is read by application-prod.properties when running OUTSIDE Docker, e.g.
# `SPRING_PROFILES_ACTIVE=prod java -jar paydude.jar` against a managed Postgres. Ignored by
# docker-compose because the URL is built from DB_NAME inside the Compose file.
# DB_URL=jdbc:postgresql://your-host:5432/paydude_db

# ---- JWT (access token) ----
# Generate a fresh 32-byte Base64 key per environment:
#   openssl rand -base64 32
# The default baked into application-dev.properties is for local convenience only — never reuse it
# anywhere a real token could leak. The production overlay (docker-compose.prod.yml) makes
# JWT_SECRET_KEY mandatory and the `docker compose up` invocation fails fast if unset.
JWT_SECRET_KEY=replace_me
# Access-token lifetime in ms. 15 min (900000) is the recommended value once refresh tokens are
# wired — short enough to bound the blast radius of theft, long enough that the refresh path is
# not on the per-request hot path.
JWT_EXPIRATION_TIME=900000

# ---- Refresh tokens ----
# Lifetime of an opaque refresh token before the user must re-login. Format: ISO-8601 (PT168H) or
# Spring's friendlier DurationStyle (`168h`, `7d`). 7 days is the default in dev/prod profiles;
# tighten per regulated tenant if compliance demands it.
# REFRESH_TOKEN_EXPIRATION=PT168H

# ---- Credential rotation policy (prod-only override) ----
# 0 disables the policy (NIST SP 800-63B default — periodic forced rotation discouraged).
# Set to a positive integer only when a compliance regime (PCI-DSS v3, regulated banking) requires
# it. Dev and test profiles ignore this and hard-code 90 to exercise the full UserDetails contract.
# CREDENTIALS_EXPIRATION_DAYS=0

# ---- Auth rate limits (prod-only overrides) ----
# Token-bucket thresholds enforced by AuthRateLimiter. Tightening these is a deploy-free lever
# during a credential-stuffing incident — drop login-by-email capacity, restart the pod.
# Defaults shown match application-prod.properties / application-dev.properties.
# RATE_LIMIT_LOGIN_IP_CAPACITY=20
# RATE_LIMIT_LOGIN_IP_PERIOD=1m
# RATE_LIMIT_LOGIN_EMAIL_CAPACITY=5
# RATE_LIMIT_LOGIN_EMAIL_PERIOD=15m
# RATE_LIMIT_REGISTER_IP_CAPACITY=5
# RATE_LIMIT_REGISTER_IP_PERIOD=1h
# Throttle for POST /v1/auth/refresh — a legit client refreshes ~4×/hour per active session, so 60/h
# leaves headroom for multiple devices/tabs while still cutting off enumeration attempts.
# RATE_LIMIT_REFRESH_IP_CAPACITY=60
# RATE_LIMIT_REFRESH_IP_PERIOD=1h

# ---- CORS (mandatory under the prod profile / prod overlay) ----
# application-prod.properties has no default — the production overlay surfaces the same
# requirement at the compose layer so a misconfigured deploy fails at `docker compose up`
# time instead of at the first browser request.
# Comma-separated list of first-party frontend origins. Wildcards are not allowed by Spring
# Security when allowCredentials is true; this app uses Bearer headers (allowCredentials=false)
# so wildcards would technically work, but listing exact origins reduces the recon surface.
# CORS_ALLOWED_ORIGINS=https://app.paydude.com,https://admin.paydude.com

# ---- Actuator scraper credential ----
# Basic-auth password for the admin tier of Actuator (/actuator/prometheus, /metrics, /loggers,
# /configprops, /env). The dev profile and the base docker-compose.yml bake `local-actuator-secret`
# for convenience (matched in observability/prometheus.yml), so the local Grafana stack scrapes
# with no setup. The prod overlay makes it mandatory. The username defaults to `prometheus`
# (override with ACTUATOR_USERNAME if your scraper needs a different one). If you set a real
# ACTUATOR_PASSWORD, update observability/prometheus.yml to match (Prometheus does not expand env
# vars in its config).
# ACTUATOR_PASSWORD=replace_me
# ACTUATOR_USERNAME=prometheus

# ---- HaveIBeenPwned breach screening (prod-only override) ----
# Toggle for the NIST SP 800-63B §5.1.1.2 screening. `true` is the cross-profile default
# (set in application.properties and inherited by prod). Override to `false` only for
# air-gapped deployments that cannot reach the public HIBP API — the check already
# fails open on a transient outage, so the override is for "by policy" disconnection,
# not unreliable connectivity. Dev profile inherits the base `true`; test profile hardcodes
# `false` to keep ITs off the public network.
# PASSWORD_BREACH_CHECK_ENABLED=true

# ---- Idempotency key retention (prod-only override) ----
# How long a reserved Idempotency-Key row stays queryable before the cleanup job (pending) is
# allowed to purge it. Compliance regimes that mandate shorter retention of request fingerprints
# (e.g. PCI-DSS scope reduction) can lower this without code changes; the cleanup job will read
# the same value to align its scan window.
# Format: ISO-8601 (`PT24H`) or Spring's friendlier `24h` / `7d`.
# IDEMPOTENCY_KEY_TTL=24d