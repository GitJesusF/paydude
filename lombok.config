# Marks this file as the root of Lombok's configuration for the project. Without it, Lombok
# walks up the directory tree (parent folder, grandparent, …) looking for additional
# lombok.config files and merges them in. Setting this to true keeps the project's behavior
# self-contained and reproducible across machines: anyone building the repo gets exactly
# the rules defined here, regardless of what configs may exist higher up in their filesystem.
config.stopBubbling = true

# Tells Lombok which annotations should be copied from the @RequiredArgsConstructor field
# down to the generated constructor parameter. Spring needs @Qualifier on the parameter
# (not the field) to disambiguate when multiple beans of the same type exist — without this,
# Lombok would drop the annotation and Spring would fail with NoUniqueBeanDefinitionException.
lombok.copyableAnnotations += org.springframework.beans.factory.annotation.Qualifier