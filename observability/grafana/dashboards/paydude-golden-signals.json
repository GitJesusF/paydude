{
  "annotations": {
    "list": []
  },
  "editable": false,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "type": "row",
      "title": "Transfers",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Transfer rate (completed vs failed)",
      "description": "Successful transfers per second (rate over 1m) vs failed transfers broken down by domain reason.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 1 },
      "id": 1,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(paydude_transfer_completed_total[1m])",
          "legendFormat": "completed",
          "refId": "A"
        },
        {
          "expr": "sum by (reason) (rate(paydude_transfer_failed_total[1m]))",
          "legendFormat": "failed: {{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10,
            "stacking": { "mode": "none" }
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "table", "placement": "bottom", "calcs": ["mean", "max"] },
        "tooltip": { "mode": "multi", "sort": "desc" }
      }
    },
    {
      "type": "timeseries",
      "title": "Transfer latency p50 / p95 / p99",
      "description": "Wall-clock duration of a transfer attempt (success or failure). Pin SLOs on p95.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 1 },
      "id": 2,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(paydude_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p50",
          "refId": "A"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(paydude_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p95",
          "refId": "B"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(paydude_transfer_duration_seconds_bucket[5m])) by (le))",
          "legendFormat": "p99",
          "refId": "C"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 0
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "row",
      "title": "Auth & idempotency",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 9 },
      "id": 101,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Login outcome rate",
      "description": "Success vs failure rate of /v1/auth/login. A sustained spike of failures is the canonical credential-stuffing signal.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(paydude_auth_login_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "Idempotency: replays vs conflicts",
      "description": "Replays are work the layer saved (cache hits). Conflicts indicate buggy clients or replay attacks.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "rate(paydude_idempotency_replay_total[1m])",
          "legendFormat": "replay (cache hit)",
          "refId": "A"
        },
        {
          "expr": "sum by (reason) (rate(paydude_idempotency_conflict_total[1m]))",
          "legendFormat": "conflict: {{reason}}",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "row",
      "title": "Account security (lockout & MFA)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 18 },
      "id": 104,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "Account lockouts & registrations",
      "description": "Lockouts in the last 5m: accounts that crossed lockout.max-attempts (pattern #22). One account locking is a forgotten password; many distinct accounts locking together is the credential-stuffing signature — read alongside 'Login outcome rate'. Registrations ride along as the sign-up baseline.",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 19 },
      "id": 10,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "increase(paydude_auth_lockout_total[5m])",
          "legendFormat": "lockouts (5m)",
          "refId": "A"
        },
        {
          "expr": "increase(paydude_auth_register_total[5m])",
          "legendFormat": "registrations (5m)",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "timeseries",
      "title": "MFA verification outcome rate",
      "description": "TOTP / recovery-code verifications at the step-up login (pattern #24). A failure spike is someone guessing codes — each wrong code also feeds the same lockout as a wrong password, so cross-check with the lockout panel.",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 19 },
      "id": 11,
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(paydude_auth_mfa_total[1m]))",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "ops",
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 10
          }
        },
        "overrides": []
      },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      }
    },
    {
      "type": "row",
      "title": "JVM & HTTP (built-in Spring Boot meters)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 27 },
      "id": 102,
      "collapsed": true,
      "panels": [
        {
          "type": "stat",
          "title": "JVM heap used",
          "gridPos": { "h": 4, "w": 6, "x": 0, "y": 28 },
          "id": 5,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "sum(jvm_memory_used_bytes{area=\"heap\"})",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": { "unit": "bytes" },
            "overrides": []
          }
        },
        {
          "type": "stat",
          "title": "HTTP server requests / s",
          "gridPos": { "h": 4, "w": 6, "x": 6, "y": 28 },
          "id": 6,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "sum(rate(http_server_requests_seconds_count[1m]))",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": { "unit": "reqps" },
            "overrides": []
          }
        },
        {
          "type": "stat",
          "title": "DB connections active",
          "gridPos": { "h": 4, "w": 6, "x": 12, "y": 28 },
          "id": 7,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "hikaricp_connections_active",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": { "unit": "short" },
            "overrides": []
          }
        },
        {
          "type": "stat",
          "title": "Uptime",
          "gridPos": { "h": 4, "w": 6, "x": 18, "y": 28 },
          "id": 8,
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "targets": [
            {
              "expr": "process_uptime_seconds",
              "refId": "A"
            }
          ],
          "fieldConfig": {
            "defaults": { "unit": "s" },
            "overrides": []
          }
        }
      ]
    },
    {
      "type": "row",
      "title": "Logs (Loki)",
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 32 },
      "id": 103,
      "collapsed": false,
      "panels": []
    },
    {
      "type": "logs",
      "title": "Recent WARN/ERROR — paydude-app",
      "description": "Live tail of the paydude-app container, filtered to WARN and ERROR levels. Click a row to drill into the traceId in Explore.",
      "gridPos": { "h": 12, "w": 24, "x": 0, "y": 33 },
      "id": 9,
      "datasource": { "type": "loki", "uid": "loki" },
      "targets": [
        {
          "expr": "{container=\"paydude-app\"} | json | level=~\"WARN|ERROR\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": false,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": false,
        "enableLogDetails": true,
        "dedupStrategy": "none",
        "sortOrder": "Descending"
      }
    }
  ],
